{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lidhra",
  "version": "0.1.0",
  "identifier": "dev.peterdsp.lidhra",
  "build": {
    "frontendDist": "../../ui"
  },
  "app": {
    "windows": [
      {
        "title": "Lidhra",
        "label": "main",
        "width": 960,
        "height": 700,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/peterdsp/lidhra/releases/latest/download/latest.json"],
      "pubkey": "REPLACE_WITH_OUTPUT_OF_tauri_signer_generate"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
